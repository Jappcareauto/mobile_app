<manifest xmlns:android="http://schemas.android.com/apk/res/android">
  <!-- ================================================================
         PERMISSIONS – Google Play User Data Policy compliance
         ================================================================

         FOREGROUND LOCATION – used by maps, service locator, vehicle finder.
         Requested AFTER showing the Prominent Disclosure bottom sheet.
    ================================================================ -->
  <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
  <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

  <!-- ================================================================
         BACKGROUND LOCATION
         ================================================================
         Requested ONLY:
           1. After foreground location is already granted.
           2. After the user accepts BackgroundLocationRationaleBottomSheet.
           3. On Android 11+ the OS routes the user to system settings to
              select "Allow all the time".

         Google Play review checklist:
           Prominent Disclosure shown before any OS dialog.
           Separate background-location rationale shown separately.
           Feature list names background use cases (emergency SOS,
              roadside assistance tracking).
           User can decline background access without losing foreground.

         Ref: https://support.google.com/googleplay/android-developer/answer/9799150
    ================================================================ -->
  <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

  <!-- ================================================================
         FOREGROUND SERVICE – legally required to access location in the
         background via a ForegroundService (Android 9+).
         FOREGROUND_SERVICE_LOCATION type is mandatory on Android 14+.
    ================================================================ -->
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

  <uses-permission android:name="android.permission.INTERNET" />
  <uses-permission android:name="android.permission.RECORD_AUDIO" />
  <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />

  <application
    android:label="Jappcare"
    android:name="${applicationName}"
    android:icon="@mipmap/ic_launcher"
  >
    <activity
      android:name=".MainActivity"
      android:exported="true"
      android:launchMode="singleTop"
      android:taskAffinity=""
      android:theme="@style/LaunchTheme"
      android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
      android:hardwareAccelerated="true"
      android:enableOnBackInvokedCallback="true"
      android:windowSoftInputMode="adjustResize"
    >
      <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
      <meta-data
        android:name="io.flutter.embedding.android.NormalTheme"
        android:resource="@style/NormalTheme"
      />
      <intent-filter>
        <action android:name="android.intent.action.MAIN" />
        <category android:name="android.intent.category.LAUNCHER" />
      </intent-filter>
    </activity>

    <!-- ================================================================
             FOREGROUND SERVICE DECLARATION
             Required on Android 8+ for long-lived location tasks (active
             emergency or roadside-assistance tracking sessions).
             android:foregroundServiceType="location" is mandatory on
             Android 10+ when a foreground service accesses location.
        ================================================================ -->
    <service
      android:name=".LocationForegroundService"
      android:enabled="true"
      android:exported="false"
      android:foregroundServiceType="location"
    />

    <meta-data
      android:name="com.google.android.geo.API_KEY"
      android:value="AIzaSyBy9Mq91oGtmrw1jKiRrDvKWwGpQgtzt3I"
    />

    <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
    <meta-data android:name="flutterEmbedding" android:value="2" />
  </application>

  <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
  <queries>
    <intent>
      <action android:name="android.intent.action.PROCESS_TEXT" />
      <data android:mimeType="text/plain" />
    </intent>
  </queries>
</manifest>
